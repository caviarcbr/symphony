#!/bin/bash

STATE_FILE="/tmp/focus-mode-state"

workspace_id=$(hyprctl activeworkspace -j | jq -r .id)
gaps=$(hyprctl workspacerules -j | jq -r ".[] | select(.workspaceString == \"$workspace_id\") | .gapsOut[0] // 0")

if [[ $gaps == "0" ]]; then
	# Switch to Vibe Mode
	hyprctl eval "hl.workspace_rule({ workspace = \"$workspace_id\", gaps_out = 10, gaps_in = 4, border_size = 2 })"
	hyprctl eval 'hl.config({ decoration = { rounding = 15 } })'
	hyprctl eval 'hl.config({ animations = { enabled = true } })'

	sed -i 's/background_opacity 1$/background_opacity 0.65/g' ~/.config/kitty/kitty.conf
	pkill -SIGUSR1 -x kitty
	restart-app waybar

	rm -f "$STATE_FILE"
	notify-send "Vibe Mode"
else
	# Switch to Focus Mode
	hyprctl eval "hl.workspace_rule({ workspace = \"$workspace_id\", gaps_out = 0, gaps_in = 0, border_size = 1 })"
	hyprctl eval 'hl.config({ decoration = { rounding = 0 } })'
	hyprctl eval 'hl.config({ animations = { enabled = false } })'

	sed -i 's/background_opacity 0\.65$/background_opacity 1/g' ~/.config/kitty/kitty.conf
	pkill -SIGUSR1 -x kitty
	pkill waybar

	touch "$STATE_FILE"
	notify-send "Focus Mode"
fi
