#!/usr/bin/env bash

focused="$(hyprctl monitors -j | jq -r '.[] | select(.focused == true).name')"

while read -r monitor; do
    hyprctl dispatch "hl.dsp.focus({ monitor = \"$monitor\" })"

    hyprctl dispatch \
        "hl.dsp.exec_cmd([[alacritty --class Screensaver --config-file ~/.config/alacritty/screensaver.toml -e ~/.local/bin/screensaver]])"

done < <(
    hyprctl monitors -j | jq -r '.[].name'
)

hyprctl dispatch "hl.dsp.focus({ monitor = \"$focused\" })"
