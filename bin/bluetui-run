#!/usr/bin/env bash

STATE_DIR=~/.local/state/symphony/

if [[ ! -f "$STATE_DIR/bluetooth-first-run" ]]; then
  notify-send -u critical "Bluetooth setup" "TAB to cycle between catergories\n Arrow keys or Vim-keys (H, J, K, L) to navigate\n 'Q' to quit"
  kitty --title bluetooth -e bluetui
  touch "$STATE_DIR/bluetooth-first-run"
else
  kitty --title bluetooth -e bluetui
fi


